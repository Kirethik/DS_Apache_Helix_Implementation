<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console output: INFO and above -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%-5level] [%-20logger{20}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Full debug log to file -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/train-booking.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] [%-35logger{35}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress noisy Helix / ZooKeeper internal logs on console -->
    <logger name="org.apache.helix"     level="WARN"  additivity="false">
        <appender-ref ref="FILE"/>
    </logger>
    <logger name="org.apache.zookeeper" level="WARN"  additivity="false">
        <appender-ref ref="FILE"/>
    </logger>
    <logger name="org.I0Itec"           level="WARN"  additivity="false">
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Our application logs at DEBUG → file, INFO → console -->
    <logger name="com.trainbooking" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
